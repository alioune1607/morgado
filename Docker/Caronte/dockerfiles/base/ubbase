FROM ubuntu:22.04

# Instalación de paquetería base
RUN apt-get update && apt-get install -y curl git openssh-server sudo iproute2

# Creación del usuario alioune y configuración de sudo
RUN useradd -rm -d /home/alioune -s /bin/bash -g root -G sudo -u 1000 alioune && \
    echo 'alioune:alioune' | chpasswd

# Configuración del SSH
RUN mkdir /var/run/sshd

# Copiar el script de inicio
COPY start.sh /usr/local/bin/start.sh
RUN chmod +x /usr/local/bin/start.sh

ENTRYPOINT ["/usr/local/bin/start.sh"]
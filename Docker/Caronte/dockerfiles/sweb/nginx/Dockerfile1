# 1. Usamos tu propia imagen base como punto de partida
FROM alioune/ubbase

# 2. Instalación de Nginx
RUN apt-get update && apt-get install -y nginx

# 3. Dar la propiedad a www-data y permisos 755 (Requisito del examen)
RUN chown -R www-data:www-data /var/www/html && \
    chmod -R 755 /var/www/html

# 4. Exponer el puerto 80
EXPOSE 80

# 5. Copiar el nuevo entrypoint de Nginx
COPY start.sh /usr/local/bin/start-nginx.sh
RUN chmod +x /usr/local/bin/start-nginx.sh

# 6. Definir el nuevo entrypoint
ENTRYPOINT ["/usr/local/bin/start-nginx.sh"]